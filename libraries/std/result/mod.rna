pub enum Result[T, E]:
    Ok(T)
    Err(E)

impl[T, E] Result[T, E]:
    fn is_ok(read self) -> Bool:
        select self:
            when Result.Ok(value) => return true
            when Result.Err(error) => return false
        return false

    fn is_err(read self) -> Bool:
        select self:
            when Result.Err(error) => return true
            when Result.Ok(value) => return false
        return false
